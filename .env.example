# Environment Configuration for LDCE Connect
# Copy this file to .env and fill in your values
# DO NOT commit the .env file to version control

# ============================================
# API Configuration
# ============================================
API_BASE_URL=https://ldcealumniapi.devitsandbox.com/api/
# API_BASE_URL=http://api.ldcealumni.net/api/

# ============================================
# Firebase Configuration
# ============================================
FIREBASE_PROJECT_ID=ldce-alumni-bd8d4
FIREBASE_STORAGE_BUCKET=ldce-alumni-bd8d4.appspot.com

# ============================================
# FCM Topic Subscriptions
# ============================================
FCM_TOPIC_ALL=all
FCM_TOPIC_ANDROID=all-android
FCM_TOPIC_IOS=all-ios
FCM_TOPIC_DEV=all-dhrumil

# ============================================
# App Configuration
# ============================================
APP_NAME=LDCE Connect
APP_PACKAGE=net.ldcealumni
HTTP_TIMEOUT=40

# ============================================
# Build Configuration
# ============================================
ENVIRONMENT=development
# ENVIRONMENT=staging
# ENVIRONMENT=production
